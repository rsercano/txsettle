# Solana devnet RPC. The public endpoint rate-limits aggressively (429);
# point this at a Helius/Triton/QuickNode devnet endpoint for a smoother demo.
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# TxLINE devnet credentials — used BROWSER-SIDE to fetch settlement proofs.
# This is a devnet demo token for hackathon data; acceptable to expose.
NEXT_PUBLIC_TXLINE_API_TOKEN=
NEXT_PUBLIC_TXLINE_API_BASE=https://txline-dev.txodds.com/api
NEXT_PUBLIC_TXLINE_AUTH_URL=https://txline-dev.txodds.com/auth/guest/start

# Server-side only: keypair that is the mint authority of the mock-USDC mint.
# Used by POST /api/faucet to mint test USDC to visitors (throwaway devnet key).
DEV_WALLET_PATH=
