{
  "name": "txsettle",
  "version": "0.1.0",
  "private": true,
  "description": "TxSettle — trustless settlement infrastructure for TxLINE prediction markets on Solana. Built for the TxODDS x Solana World Cup Hackathon 2026 (Prediction Markets & Settlement track).",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces",
    "test:program": "anchor test --provider.cluster localnet --validator legacy",
    "e2e:devnet": "tsx scripts/e2e-devnet.ts",
    "typecheck": "npm run typecheck --workspaces"
  },
  "author": "Sercan Ozdemir (https://github.com/rsercano)",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20 <21"
  },
  "devDependencies": {
    "@anchor-lang/core": "^1.1.2",
    "@solana/spl-token": "^0.4.15",
    "@types/node": "^26.1.1",
    "dotenv": "^17.4.2",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
